{
  "enabled": false,
  "domains": [
    {
      "domain": "example.com",
      "selector": "default",
      "private_key_path": "config/dkim/example.com.private.key",
      "algorithm": "rsa-sha256",
      "canonicalization": "relaxed/relaxed"
    }
  ],
  "fallback_domain": {
    "domain": "mail.example.com",
    "selector": "mail",
    "private_key_path": "config/dkim/fallback.private.key",
    "algorithm": "rsa-sha256",
    "canonicalization": "relaxed/relaxed"
  },
  "header_fields": [
    "From",
    "To",
    "Subject",
    "Date",
    "Message-ID",
    "MIME-Version",
    "Content-Type"
  ]
}
